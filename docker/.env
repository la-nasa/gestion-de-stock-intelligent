# ==========================================
# IUC Inventory System - Environment Variables
# ==========================================

# Environment
ENVIRONMENT=production
DEBUG=false

# Application
APP_NAME=IUC Inventory System
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
WS_URL=ws://localhost:8000

# Django
SECRET_KEY=change-this-to-a-very-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# Database
DB_NAME=iuc_inventory
DB_USER=iuc_user
DB_PASSWORD=change-this-database-password
DB_HOST=postgres
DB_PORT=5432

# Redis
REDIS_PASSWORD=change-this-redis-password
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=change-this-rabbitmq-password
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-this-minio-password
MINIO_BUCKET_NAME=iuc-inventory
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# JWT
JWT_SECRET_KEY=change-this-jwt-secret-key
JWT_ACCESS_TOKEN_EXPIRES=30
JWT_REFRESH_TOKEN_EXPIRES=1440

# Monitoring
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Ports
HTTP_PORT=80
HTTPS_PORT=443
BACKEND_PORT=8000
FRONTEND_PORT=3000
ML_SERVICE_PORT=8001
MLFLOW_PORT=5000
FLOWER_PORT=5555
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
GRAFANA_URL=http://localhost:3001

# Flower
FLOWER_USER=admin
FLOWER_PASSWORD=admin
