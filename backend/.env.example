# Django Settings
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgres://iuc_user:iuc_password@localhost:5432/iuc_inventory
DB_NAME=iuc_inventory
DB_USER=iuc_user
DB_PASSWORD=iuc_password
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_URL=redis://localhost:6379/1
REDIS_CELERY_URL=redis://localhost:6379/2

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=iuc-inventory

# JWT Settings
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ACCESS_TOKEN_EXPIRES=30
JWT_REFRESH_TOKEN_EXPIRES=1440

# Sentry
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=IUC Inventory System <noreply@iuc.cm>

# ML Service
ML_SERVICE_URL=http://localhost:8001
ML_SERVICE_API_KEY=your-ml-service-key

# Application
APP_NAME=IUC Inventory System
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
